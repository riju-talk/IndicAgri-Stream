{
  "dashboard": {
    "title": "IndicAgri-Stream Pipeline Overview",
    "tags": ["agriculture", "kafka", "pipeline"],
    "timezone": "browser",
    "panels": [
      {
        "id": 1,
        "title": "Kafka Consumer Lag",
        "type": "graph",
        "targets": [
          {
            "expr": "kafka_consumer_lag",
            "legendFormat": "{{topic}}-{{partition}}"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0}
      },
      {
        "id": 2,
        "title": "Event Ingestion Rate",
        "type": "graph",
        "targets": [
          {
            "expr": "rate(kafka_messages_in_total[1m])",
            "legendFormat": "{{topic}}"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0}
      },
      {
        "id": 3,
        "title": "API Response Time (p95)",
        "type": "graph",
        "targets": [
          {
            "expr": "histogram_quantile(0.95, rate(api_request_duration_seconds_bucket[5m]))",
            "legendFormat": "p95"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8}
      },
      {
        "id": 4,
        "title": "Alert Notifications Sent",
        "type": "stat",
        "targets": [
          {
            "expr": "sum(increase(alert_notifications_total[1h]))",
            "legendFormat": "Total Alerts"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8}
      },
      {
        "id": 5,
        "title": "DLQ Message Count",
        "type": "stat",
        "targets": [
          {
            "expr": "dlq_message_count",
            "legendFormat": "Failed Messages"
          }
        ],
        "gridPos": {"h": 8, "w": 6, "x": 0, "y": 16},
        "alert": {
          "name": "DLQ Alert",
          "conditions": [
            {
              "evaluator": {"params": [50], "type": "gt"},
              "operator": {"type": "and"},
              "query": {"params": ["A", "5m", "now"]},
              "reducer": {"params": [], "type": "avg"},
              "type": "query"
            }
          ]
        }
      },
      {
        "id": 6,
        "title": "Airflow DAG Success Rate",
        "type": "gauge",
        "targets": [
          {
            "expr": "airflow_dag_success_rate",
            "legendFormat": "Success %"
          }
        ],
        "gridPos": {"h": 8, "w": 6, "x": 6, "y": 16}
      }
    ],
    "refresh": "30s",
    "schemaVersion": 38,
    "version": 1
  }
}
